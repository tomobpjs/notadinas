  FileText, 
  Database, 
  PackageCheck, 
  FileBarChart, 
  Plus, 
  Trash2, 
  Save, 
  Search,
  Download,
  Camera,
  CheckCircle2,
  Clock,
  XCircle,
  RotateCcw,
  AlertCircle,
  Edit3,
  X
} from 'lucide-react';

